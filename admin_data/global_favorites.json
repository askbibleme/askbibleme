{
  "items": {
    "cuvs_zh|GEN|1|20": {
      "key": "cuvs_zh|GEN|1|20",
      "type": "verse",
      "count": 3,
      "createdAt": "2026-04-01T14:49:01.828Z",
      "updatedAt": "2026-04-05T19:18:32.655Z",
      "bookId": "GEN",
      "chapter": 1,
      "verse": 20,
      "title": "GEN 1章:20",
      "content": "神说：「水要多多滋生有生命的物；要有雀鸟飞在地面以上，天空之中。」",
      "contentVersion": "",
      "contentLang": ""
    },
    "cuvs_zh|GEN|1|21": {
      "key": "cuvs_zh|GEN|1|21",
      "type": "verse",
      "count": 3,
      "createdAt": "2026-04-01T14:49:01.834Z",
      "updatedAt": "2026-04-05T19:18:38.257Z",
      "bookId": "GEN",
      "chapter": 1,
      "verse": 21,
      "title": "GEN 1章:21",
      "content": "神就造出大鱼和水中所滋生各样有生命的动物，各从其类；又造出各样飞鸟，各从其类。神看着是好的。",
      "contentVersion": "",
      "contentLang": ""
    },
    "cuvs_zh|GEN|1|26": {
      "key": "cuvs_zh|GEN|1|26",
      "type": "verse",
      "count": 2,
      "createdAt": "2026-04-01T15:45:54.718Z",
      "updatedAt": "2026-04-01T15:46:21.719Z",
      "bookId": "GEN",
      "chapter": 1,
      "verse": 26,
      "title": "GEN 1章:26",
      "content": "神说：「我们要照着我们的形像、按着我们的样式造人，使他们管理海里的鱼、空中的鸟、地上的牲畜和全地，并地上所爬的一切昆虫。」",
      "contentVersion": "",
      "contentLang": ""
    },
    "cuvs_zh|GEN|1|2": {
      "key": "cuvs_zh|GEN|1|2",
      "type": "verse",
      "count": 2,
      "createdAt": "2026-04-01T15:46:04.724Z",
      "updatedAt": "2026-04-05T19:17:50.870Z",
      "bookId": "GEN",
      "chapter": 1,
      "verse": 2,
      "title": "GEN 1章:2",
      "content": "地是空虚混沌，渊面黑暗；神的灵运行在水面上。",
      "contentVersion": "",
      "contentLang": ""
    },
    "qfav_2b31f21a": {
      "key": "qfav_2b31f21a",
      "type": "question",
      "count": 2,
      "createdAt": "2026-04-04T02:53:25.443Z",
      "updatedAt": "2026-04-04T02:54:56.667Z",
      "bookId": "GEN",
      "chapter": 4,
      "verse": 0,
      "title": "该隐后代的发展：文明增长，罪也继续加深",
      "content": "17-22节记载了建城、牧养、音乐、打造器具等发展。你看到人类文化和技术有哪些进步？",
      "contentVersion": "default",
      "contentLang": "zh"
    },
    "qfav_26121df3": {
      "key": "qfav_26121df3",
      "type": "question",
      "count": 2,
      "createdAt": "2026-04-04T02:53:28.678Z",
      "updatedAt": "2026-04-04T02:54:56.662Z",
      "bookId": "GEN",
      "chapter": 4,
      "verse": 0,
      "title": "该隐后代的发展：文明增长，罪也继续加深",
      "content": "从该隐到拉麦，你觉得罪是被控制住了，还是在扩张？经文是怎样一步步写出来的？",
      "contentVersion": "default",
      "contentLang": "zh"
    },
    "qfav_577c8c36": {
      "key": "qfav_577c8c36",
      "type": "question",
      "count": 2,
      "createdAt": "2026-04-04T03:12:39.172Z",
      "updatedAt": "2026-04-04T03:14:59.661Z",
      "bookId": "GEN",
      "chapter": 16,
      "verse": 0,
      "title": "等候中的焦急与人的安排",
      "content": "撒莱提出用夏甲生子时，她是怎样理解这件事的？这反映出她想用什么方式解决问题？",
      "contentVersion": "default",
      "contentLang": "zh"
    },
    "qfav_e909dde8": {
      "key": "qfav_e909dde8",
      "type": "question",
      "count": 2,
      "createdAt": "2026-04-04T03:12:40.081Z",
      "updatedAt": "2026-04-04T03:14:59.664Z",
      "bookId": "GEN",
      "chapter": 16,
      "verse": 0,
      "title": "等候中的焦急与人的安排",
      "content": "亚伯兰“听从了撒莱的话”，经文没有多解释，你觉得这句话让人看见他在这件事上怎样的角色？",
      "contentVersion": "default",
      "contentLang": "zh"
    },
    "qfav_732de873": {
      "key": "qfav_732de873",
      "type": "question",
      "count": 2,
      "createdAt": "2026-04-04T03:12:41.213Z",
      "updatedAt": "2026-04-04T03:14:59.671Z",
      "bookId": "GEN",
      "chapter": 16,
      "verse": 0,
      "title": "等候中的焦急与人的安排",
      "content": "第1-3节怎样交代当时的处境？哪些信息让你感受到撒莱的压力和着急？",
      "contentVersion": "default",
      "contentLang": "zh"
    },
    "qfav_5b37eccf": {
      "key": "qfav_5b37eccf",
      "type": "question",
      "count": 2,
      "createdAt": "2026-04-04T03:12:42.145Z",
      "updatedAt": "2026-04-04T03:14:59.669Z",
      "bookId": "GEN",
      "chapter": 16,
      "verse": 0,
      "title": "等候中的焦急与人的安排",
      "content": "经文特别提到亚伯兰已经在迦南住了十年，这个时间点对理解他们的决定有什么帮助？",
      "contentVersion": "default",
      "contentLang": "zh"
    },
    "qfav_56d220a2": {
      "key": "qfav_56d220a2",
      "type": "question",
      "count": 2,
      "createdAt": "2026-04-04T03:12:43.198Z",
      "updatedAt": "2026-04-04T03:14:59.666Z",
      "bookId": "GEN",
      "chapter": 16,
      "verse": 0,
      "title": "怀孕之后，关系立刻破裂",
      "content": "夏甲怀孕以后，态度发生了什么变化？她为什么可能会“小看”撒莱？",
      "contentVersion": "default",
      "contentLang": "zh"
    },
    "qfav_75bab1fe": {
      "key": "qfav_75bab1fe",
      "type": "question",
      "count": 2,
      "createdAt": "2026-04-04T03:12:44.120Z",
      "updatedAt": "2026-04-04T03:14:59.657Z",
      "bookId": "GEN",
      "chapter": 16,
      "verse": 0,
      "title": "怀孕之后，关系立刻破裂",
      "content": "撒莱在第5节把委屈向谁倾诉？她的话里有哪些埋怨、推责或受伤的情绪？",
      "contentVersion": "default",
      "contentLang": "zh"
    },
    "qfav_9b269d25": {
      "key": "qfav_9b269d25",
      "type": "question",
      "count": 2,
      "createdAt": "2026-04-04T03:12:46.433Z",
      "updatedAt": "2026-04-04T03:14:59.655Z",
      "bookId": "GEN",
      "chapter": 16,
      "verse": 0,
      "title": "怀孕之后，关系立刻破裂",
      "content": "亚伯兰在第6节的回应解决问题了吗？从“使女在你手下，你可以随意待她”这句话，你看见他怎样处理冲突？",
      "contentVersion": "default",
      "contentLang": "zh"
    },
    "qfav_b7d292c7": {
      "key": "qfav_b7d292c7",
      "type": "question",
      "count": 2,
      "createdAt": "2026-04-04T03:12:47.158Z",
      "updatedAt": "2026-04-04T03:14:59.646Z",
      "bookId": "GEN",
      "chapter": 16,
      "verse": 0,
      "title": "怀孕之后，关系立刻破裂",
      "content": "这一段里，三个人都在用自己的方式回应压力。哪一种反应最容易在现实关系中重复出现？",
      "contentVersion": "default",
      "contentLang": "zh"
    },
    "cuvs_zh|GEN|4|20": {
      "key": "cuvs_zh|GEN|4|20",
      "type": "verse",
      "count": 1,
      "createdAt": "2026-04-04T07:10:15.881Z",
      "updatedAt": "2026-04-04T07:15:50.132Z",
      "bookId": "GEN",
      "chapter": 4,
      "verse": 20,
      "title": "GEN 4章:20",
      "content": "亚大生雅八；雅八就是住帐棚、牧养牲畜之人的祖师。",
      "contentVersion": "",
      "contentLang": ""
    },
    "cuvs_zh|GEN|4|1": {
      "key": "cuvs_zh|GEN|4|1",
      "type": "verse",
      "count": 1,
      "createdAt": "2026-04-04T07:13:04.534Z",
      "updatedAt": "2026-04-04T07:15:47.307Z",
      "bookId": "GEN",
      "chapter": 4,
      "verse": 1,
      "title": "GEN 4章:1",
      "content": "有一日，那人和他妻子夏娃同房，夏娃就怀孕，生了该隐〔就是得的意思〕，便说：「耶和华使我得了一个男子。」",
      "contentVersion": "",
      "contentLang": ""
    },
    "cuvs_zh|GEN|4|18": {
      "key": "cuvs_zh|GEN|4|18",
      "type": "verse",
      "count": 1,
      "createdAt": "2026-04-04T14:58:20.423Z",
      "updatedAt": "2026-04-04T14:59:30.736Z",
      "bookId": "GEN",
      "chapter": 4,
      "verse": 18,
      "title": "GEN 4章:18",
      "content": "以诺生以拿；以拿生米户雅利；米户雅利生玛土撒利；玛土撒利生拉麦。",
      "contentVersion": "",
      "contentLang": ""
    },
    "cuvs_zh|GEN|1|22": {
      "key": "cuvs_zh|GEN|1|22",
      "type": "verse",
      "count": 2,
      "createdAt": "2026-04-05T18:42:38.109Z",
      "updatedAt": "2026-04-05T19:18:30.056Z",
      "bookId": "GEN",
      "chapter": 1,
      "verse": 22,
      "title": "GEN 1章:22",
      "content": "神就赐福给这一切，说：「滋生繁多，充满海中的水；雀鸟也要多生在地上。」",
      "contentVersion": "",
      "contentLang": ""
    },
    "qfav_7257df6c": {
      "key": "qfav_7257df6c",
      "type": "question",
      "count": 2,
      "createdAt": "2026-04-05T18:42:41.107Z",
      "updatedAt": "2026-04-05T18:46:03.796Z",
      "bookId": "GEN",
      "chapter": 1,
      "verse": 0,
      "title": "第五日：水中与空中的生命",
      "content": "第22节是本章第一次明确出现“赐福”，神赐福的内容是什么？这和前面单单“造出来”相比，多了什么意义？",
      "contentVersion": "default",
      "contentLang": "zh"
    },
    "cuvs_zh|GEN|1|24": {
      "key": "cuvs_zh|GEN|1|24",
      "type": "verse",
      "count": 1,
      "createdAt": "2026-04-05T18:42:45.908Z",
      "updatedAt": "2026-04-05T19:17:48.987Z",
      "bookId": "GEN",
      "chapter": 1,
      "verse": 24,
      "title": "GEN 1章:24",
      "content": "神说：「地要生出活物来，各从其类；牲畜、昆虫、野兽，各从其类。」事就这样成了。",
      "contentVersion": "",
      "contentLang": ""
    },
    "cuvs_zh|GEN|1|28": {
      "key": "cuvs_zh|GEN|1|28",
      "type": "verse",
      "count": 2,
      "createdAt": "2026-04-05T18:44:46.168Z",
      "updatedAt": "2026-04-05T18:46:03.778Z",
      "bookId": "GEN",
      "chapter": 1,
      "verse": 28,
      "title": "GEN 1章:28",
      "content": "神就赐福给他们，又对他们说：「要生养众多，遍满地面，治理这地，也要管理海里的鱼、空中的鸟，和地上各样行动的活物。」",
      "contentVersion": "",
      "contentLang": ""
    },
    "cuvs_zh|GEN|1|12": {
      "key": "cuvs_zh|GEN|1|12",
      "type": "verse",
      "count": 2,
      "createdAt": "2026-04-05T18:44:54.825Z",
      "updatedAt": "2026-04-05T18:46:03.775Z",
      "bookId": "GEN",
      "chapter": 1,
      "verse": 12,
      "title": "GEN 1章:12",
      "content": "于是地发生了青草和结种子的菜蔬，各从其类；并结果子的树木，各从其类；果子都包着核。神看着是好的。",
      "contentVersion": "",
      "contentLang": ""
    },
    "cuvs_zh|GEN|5|2": {
      "key": "cuvs_zh|GEN|5|2",
      "type": "verse",
      "count": 1,
      "createdAt": "2026-04-05T19:14:20.356Z",
      "updatedAt": "2026-04-05T19:58:39.412Z",
      "bookId": "GEN",
      "chapter": 5,
      "verse": 2,
      "title": "GEN 5章:2",
      "content": "并且造男造女。在他们被造的日子，神赐福给他们，称他们为「人」。）",
      "contentVersion": "",
      "contentLang": ""
    },
    "qfav_6e69f58f": {
      "key": "qfav_6e69f58f",
      "type": "question",
      "count": 2,
      "createdAt": "2026-04-05T19:15:02.505Z",
      "updatedAt": "2026-04-05T19:16:54.617Z",
      "bookId": "GEN",
      "chapter": 1,
      "verse": 0,
      "title": "第五日：水中与空中的生命",
      "content": "从“滋生繁多，充满海中的水”“多生在地上”来看，神对生命的心意只是存在，还是发展与扩展？",
      "contentVersion": "default",
      "contentLang": "zh"
    },
    "cuvs_zh|GEN|5|5": {
      "key": "cuvs_zh|GEN|5|5",
      "type": "verse",
      "count": 2,
      "createdAt": "2026-04-05T19:28:57.152Z",
      "updatedAt": "2026-04-05T19:31:27.511Z",
      "bookId": "GEN",
      "chapter": 5,
      "verse": 5,
      "title": "GEN 5章:5",
      "content": "亚当共活了九百三十岁就死了。",
      "contentVersion": "",
      "contentLang": ""
    },
    "qfav_2fd91947": {
      "key": "qfav_2fd91947",
      "type": "question",
      "count": 2,
      "createdAt": "2026-04-05T19:28:58.699Z",
      "updatedAt": "2026-04-05T19:31:27.512Z",
      "bookId": "GEN",
      "chapter": 5,
      "verse": 0,
      "title": "按着神的样式被造，却进入会死的人生",
      "content": "第1-2节先回到“神造人”的起点，这样的开头对后面整份家谱有什么提醒？",
      "contentVersion": "default",
      "contentLang": "zh"
    },
    "qfav_c6df2127": {
      "key": "qfav_c6df2127",
      "type": "question",
      "count": 1,
      "createdAt": "2026-04-05T19:29:00.449Z",
      "updatedAt": "2026-04-05T19:42:51.270Z",
      "bookId": "GEN",
      "chapter": 5,
      "verse": 0,
      "title": "按着神的样式被造，却进入会死的人生",
      "content": "第3节说塞特“形像样式和自己相似”，这句话和前面“照着神的样式造人”放在一起看，你会想到什么变化？",
      "contentVersion": "default",
      "contentLang": "zh"
    },
    "cuvs_zh|GEN|5|8": {
      "key": "cuvs_zh|GEN|5|8",
      "type": "verse",
      "count": 2,
      "createdAt": "2026-04-05T19:29:04.152Z",
      "updatedAt": "2026-04-05T19:31:27.510Z",
      "bookId": "GEN",
      "chapter": 5,
      "verse": 8,
      "title": "GEN 5章:8",
      "content": "塞特共活了九百一十二岁就死了。",
      "contentVersion": "",
      "contentLang": ""
    },
    "cuvs_zh|GEN|1|25": {
      "key": "cuvs_zh|GEN|1|25",
      "type": "verse",
      "count": 2,
      "createdAt": "2026-04-05T22:13:08.133Z",
      "updatedAt": "2026-04-05T22:46:09.643Z",
      "bookId": "GEN",
      "chapter": 1,
      "verse": 25,
      "title": "GEN 1章:25",
      "content": "于是神造出野兽，各从其类；牲畜，各从其类；地上一切昆虫，各从其类。神看着是好的。",
      "contentVersion": "",
      "contentLang": ""
    }
  }
}