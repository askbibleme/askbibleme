.env
.env.*
!.env.example

.DS_Store

# 勿将 OpenAI 等密钥提交到 Git（后台「系统密钥」写入的文件）
admin_data/system_secrets.json

# 本地打的升级包（勿提交）
deploy-builds/

node_modules/

# 本地账号 / 统计库与部署上传缓存（勿提交）
admin_data/*.sqlite
admin_data/*.sqlite-shm
admin_data/*.sqlite-wal
admin_data/auth.db
admin_data/deploy/uploads/

# 章节插画 prompt 生成记录（首次请求时由服务器创建；勿提交个人草稿）
data/prompts.json

# OpenAI 出图缓存（运行时写入 public/generated/）；人物/插画发布用 ill- 前缀纳入版本库
public/generated/*.png
!public/generated/ill-*.png
dist-capacitor/public/generated/*.png

# 本地章节视频源文件体积过大，勿直接提交到 GitHub
chapter_videos/**/*.mp4

# 本地下载的 Node 运行时，仅用于当前机器调试
.tools/
