# 复制为 .env 后填写（.env 已被 .gitignore 忽略，不会进仓库）
# 本地开发需要调用 OpenAI 时设置其一即可：
# OPENAI_API_KEY=sk-...
#
# 读取优先级：环境变量 OPENAI_API_KEY 优先于后台「系统密钥」（admin_data/system_secrets.json）。
# 若批量任务 401 invalid_api_key：在 OpenAI 控制台换新 Key 后，改此处或后台保存其一即可。
# （system_secrets.json 已 .gitignore，勿把含真实 Key 的文件提交 Git）

OPENAI_API_KEY=

# 可选：命令行一键部署（npm run deploy:remote -- deploy-builds/xxx.zip）
# ASKBIBLE_DEPLOY_URL=https://你的域名
# ASKBIBLE_ADMIN_TOKEN=与浏览器后台请求里 Authorization: Bearer 后面相同（勿提交真实 token）
