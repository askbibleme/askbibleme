# 复制为 keystore.properties（勿提交仓库），与 release 密钥放在 android/ 目录。
#
# 生成密钥（在 android/ 目录执行）。若提示没有 Java，macOS 可用 Android Studio 自带 JBR：
#   "/Applications/Android Studio.app/Contents/jbr/Contents/Home/bin/keytool" -genkey -v -keystore askbible-release.keystore -alias askbible -keyalg RSA -keysize 2048 -validity 10000
# 已安装系统 JDK 时可直接：keytool -genkey ...
storeFile=askbible-release.keystore
storePassword=你的密钥库密码
keyAlias=askbible
keyPassword=你的密钥密码
