{
  "name": "bible-guide-final",
  "version": "13.0.1",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "DEV_LIVE_RELOAD=1 node server.js",
    "cap:sync": "npx cap sync",
    "cap:copy-web": "node scripts/copy-web-to-dist-capacitor.mjs",
    "build:deploy-zip": "npm run cap:copy-web && node scripts/build-deploy-upgrade-zip.mjs",
    "build:deploy-full-slim": "npm run cap:copy-web && node scripts/build-deploy-full-slim-zip.mjs",
    "cap:android": "npx cap open android",
    "android:icons": "bash scripts/generate-android-launcher-icons.sh",
    "web:icons": "bash scripts/refresh-app-icons.sh",
    "android:prep": "bash scripts/generate-android-launcher-icons.sh && npx cap sync android",
    "apk:stage": "node scripts/stage-release-apk.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "opencc-js": "^1.0.5"
  },
  "devDependencies": {
    "livereload": "^0.10.3",
    "typescript": "^6.0.2"
  }
}
